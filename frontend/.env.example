# Optional: only set this if you need to point axios at a remote backend.
# Leave blank in dev so requests go through the Vite proxy (/api/* → :8002).
# VITE_API_BASE_URL=http://localhost:8002/api/v1

# Media files are served from the same origin as the SPA (via Vite proxy in
# dev). Don't set VITE_MEDIA_BASE_URL — cross-origin media breaks cookie auth
# and the iframe preview (X-Frame-Options: SAMEORIGIN).
