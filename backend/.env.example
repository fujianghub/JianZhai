DEBUG=True
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://jianzhai:jianzhai@localhost:5432/jianzhai
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
MEDIA_ROOT=./media
SITE_PUBLIC_URL=http://localhost:3001
# Browser address-bar origin (LAN IP, domain, or https). Merged into CSRF_TRUSTED_ORIGINS,
# CORS_ALLOWED_ORIGINS, and ALLOWED_HOSTS hostname. Restart Django after changing .env.
# JIANZHAI_PUBLIC_ORIGIN=http://172.16.12.51:3001
# JIANZHAI_PUBLIC_ORIGIN=https://your.example.com
# When you use both localhost and LAN IP on the server, set the one you actually open;
# defaults still include http://localhost:3001 for CSRF if you browse via 127.0.0.1:3001.
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:8002
TIME_ZONE=Asia/Shanghai
LANGUAGE_CODE=zh-hans
