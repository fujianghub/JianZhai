# Production .env template. Copy to .env.prod and fill in REAL secrets.
#
#   cp .env.example.prod .env.prod
#   chmod 600 .env.prod    # only root can read it
#
# Then never commit .env.prod — gitignore already covers .env.*

# ─── Django ─────────────────────────────────────────────────────────
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(50))'
SECRET_KEY=REPLACE_ME_WITH_50_CHAR_RANDOM_STRING

# Production must be False.
DEBUG=False

# Comma-separated. Add your actual domain + any subdomains you serve.
ALLOWED_HOSTS=fujiang.jianzhai.cn,localhost

# Must be https://<domain>. Used to construct absolute URLs in RSS
# feeds, email links, etc.
SITE_PUBLIC_URL=https://fujiang.jianzhai.cn
JIANZHAI_PUBLIC_ORIGIN=https://fujiang.jianzhai.cn

# Comma-separated. Must include https://<domain>.
CSRF_TRUSTED_ORIGINS=https://fujiang.jianzhai.cn
CORS_ALLOWED_ORIGINS=https://fujiang.jianzhai.cn

# Region / locale
LANGUAGE_CODE=zh-hans
TIME_ZONE=Asia/Shanghai

# ─── Private-blog mode ──────────────────────────────────────────────
# When true, anonymous visitors get redirected to /admin/login. Friends
# get accounts via /admin/users/. Single-user dev would leave this false.
SITE_REQUIRE_LOGIN=true

# ─── Database (managed inside docker-compose) ───────────────────────
POSTGRES_DB=jianzhai
POSTGRES_USER=jianzhai
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_ME_WITH_RANDOM_PASSWORD

# Django reads DATABASE_URL — composed automatically in docker-compose.
# Don't set DATABASE_URL here; the compose file fills it in.

# ─── AI assistant (optional, but you said yes) ──────────────────────
# Without either key, the AI assistant button shows "未配置" gracefully.
# With one key, that provider's models work; the other shows "未配置".
# 出钱注意：几个朋友共享同一个 key 都会从你账单出钱。建议在
# /admin/ai → 设置 → 「每用户每日预算」 设一个上限（如 0.50 USD/天）。
ANTHROPIC_API_KEY=sk-ant-api03-PASTE_REAL_KEY_HERE
DASHSCOPE_API_KEY=sk-PASTE_REAL_KEY_HERE_OR_LEAVE_BLANK

# Default Claude model. Options: claude-opus-4-7 / claude-sonnet-4-6 /
# claude-haiku-4-5-20251001 / qwen-max / qwen-plus / qwen-turbo /
# qwen-vl-max / qwen-vl-plus.
CLAUDE_MODEL_DEFAULT=claude-opus-4-7
CLAUDE_MAX_TOKENS=1024

# ─── Media ─────────────────────────────────────────────────────────
# Inside-container path. The docker-compose volume maps this to a
# named volume so uploads survive container restarts.
MEDIA_ROOT=/app/media
